rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser(data) {
      return data.keys().hasOnly(['uid', 'email', 'name', 'pinLock', 'createdAt']) &&
             data.uid is string && data.uid.size() > 0 && data.uid.size() < 100 &&
             data.email is string && data.email.size() > 0 && data.email.size() < 100 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             (!('pinLock' in data) || (data.pinLock is string && data.pinLock.size() >= 0 && data.pinLock.size() < 10)) &&
             data.createdAt is string;
    }

    function isValidJournalEntry(data) {
      return data.keys().hasOnly(['userId', 'week', 'content', 'createdAt']) &&
             data.userId is string && data.userId.size() > 0 && data.userId.size() < 100 &&
             data.week is number && data.week > 0 && data.week <= 52 &&
             data.content is string && data.content.size() >= 0 && data.content.size() < 100000 &&
             data.createdAt is string;
    }

    function isValidTriggerLog(data) {
      return data.keys().hasOnly(['userId', 'intensity', 'trigger', 'copingMechanism', 'createdAt']) &&
             data.userId is string && data.userId.size() > 0 && data.userId.size() < 100 &&
             data.intensity is number && data.intensity >= 1 && data.intensity <= 10 &&
             data.trigger is string && data.trigger.size() > 0 && data.trigger.size() < 1000 &&
             (!('copingMechanism' in data) || (data.copingMechanism is string && data.copingMechanism.size() >= 0 && data.copingMechanism.size() < 1000)) &&
             data.createdAt is string;
    }

    function isValidPrayerWallEntry(data) {
      return data.keys().hasOnly(['authorUid', 'authorName', 'content', 'createdAt', 'likes']) &&
             data.authorUid is string && data.authorUid.size() > 0 && data.authorUid.size() < 100 &&
             data.authorName is string && data.authorName.size() > 0 && data.authorName.size() < 100 &&
             data.content is string && data.content.size() > 0 && data.content.size() < 5000 &&
             data.createdAt is string &&
             data.likes is number && data.likes >= 0;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && uidUnchanged();
      allow update: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && uidNotModified();
    }

    match /journalEntries/{entryId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid && isValidJournalEntry(request.resource.data);
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid && isValidJournalEntry(request.resource.data);
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /triggers/{triggerId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid && isValidTriggerLog(request.resource.data);
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid && isValidTriggerLog(request.resource.data);
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /prayerWall/{prayerId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.authorUid == request.auth.uid && isValidPrayerWallEntry(request.resource.data);
      allow update: if isAuthenticated() && (
        (resource.data.authorUid == request.auth.uid && request.resource.data.authorUid == request.auth.uid && isValidPrayerWallEntry(request.resource.data)) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes']) &&
         math.abs(request.resource.data.likes - resource.data.likes) == 1)
      );
      allow delete: if isAuthenticated() && resource.data.authorUid == request.auth.uid;
    }
  }
}
